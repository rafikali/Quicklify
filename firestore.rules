rules_version = '2';

// Quicklify Firestore Security Rules (Option C — no Cloud Functions).
//
// Trust boundaries:
//   - End users: signed in via Firebase Auth. May read/write their own
//     profile + own devices. May read their own subscriptions but NEVER write
//     them. May read nothing else.
//   - Admins: rows in the `admins/{uid}` collection. May read everything;
//     writes to subscriptions happen via the admin panel using the Firebase
//     Admin SDK with a service account (which bypasses these rules).
//   - Service account (admin panel server actions): bypasses rules.
//
// The "admins can't write subscriptions via client SDK" is intentional —
// it forces all premium grants through the admin panel's server actions,
// which write audit_log atomically.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.disabled == false;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // profiles: user can create + read + update own profile.
    // Update restricted to non-sensitive fields (displayName, photoUrl,
    // lastSeenAt). `banned` and `notes` only writable by service account.
    match /profiles/{uid} {
      allow create: if isOwner(uid)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.banned == false;
      allow read:   if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['displayName', 'photoUrl', 'lastSeenAt', 'email']);
      allow delete: if false;

      // Devices: user manages their own. Soft cap: client enforces 3-device
      // limit via a query before creating; sophisticated users can bypass
      // (acceptable trade-off for Option C — admin can see + revoke).
      match /devices/{deviceId} {
        allow read:   if isOwner(uid) || isAdmin();
        // User may create + update own device docs. Revocation = setting
        // revokedAt; that's an update.
        allow create: if isOwner(uid);
        allow update: if isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['lastSeenAt', 'revokedAt', 'deviceName']);
        allow delete: if isOwner(uid);
      }

      // Subscriptions: read-only for owner. Written ONLY by admin panel
      // server actions using the Admin SDK (which bypasses rules).
      match /subscriptions/{subId} {
        allow read:  if isOwner(uid) || isAdmin();
        allow write: if false;
      }

      // Activity log: per-user analytics breadcrumbs for important events
      // (downloads, premium taps, errors, etc.). The mobile app writes
      // these; admins read them in the per-user timeline. No updates or
      // deletes — the log is append-only.
      match /activity/{eventId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid);
        allow update, delete: if false;
      }
    }

    // Anonymous activity log: signed-out users keyed by their device
    // fingerprint. Same shape as profiles/{uid}/activity but lives at
    // its own root so we don't have to invent a fake uid. World-readable
    // by `get` is overkill — only admin reads it.
    match /anonymous_activity/{deviceFp}/events/{eventId} {
      allow read:   if isAdmin();
      allow create: if true;
      allow update, delete: if false;
    }

    // Admins collection: admins can see who other admins are. Writes happen
    // out-of-band (Firebase Console / manual Firestore edit).
    match /admins/{uid} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // Audit log: admins can read; nobody writes via client SDK.
    match /audit_log/{id} {
      allow read:           if isAdmin();
      allow create, update, delete: if false;
    }

    // Plans catalog: world-readable (the mobile app fetches the price list
    // without requiring sign-in). Writes happen ONLY via the admin panel
    // server actions (Admin SDK bypasses these rules).
    match /plans/{planId} {
      allow read:  if true;
      allow write: if false;
    }

    // App-wide remote config (force-update gate, blackout kill-switch,
    // latest version, APK URL). World-readable so the gate works for
    // signed-out users on first launch. Writes happen ONLY via the admin
    // panel server actions (Admin SDK bypasses these rules).
    match /config/{docId} {
      allow read:  if true;
      allow write: if false;
    }

    // Device registry: per-install heartbeat doc keyed by the device
    // fingerprint sha256. Used for device-level bans that work even when
    // the user is not signed in.
    //
    //   get  — world-readable so the unauthenticated app can check whether
    //          its own device is banned. `list` is admin-only to prevent
    //          enumeration / scraping of the registry.
    //   create — anyone can create their own device's doc on first launch,
    //            but only with non-ban fields and banned=false.
    //   update — anyone can update heartbeat fields (lastSeenAt, version,
    //            etc) on any device doc; ban fields are admin-only.
    //   delete — admin-only via SDK (rules block client deletes).
    match /device_registry/{deviceId} {
      allow get:    if true;
      allow list:   if isAdmin();
      allow create: if request.resource.data.banned == false
                    && !('banReason' in request.resource.data)
                    && !('bannedAt'  in request.resource.data)
                    && !('bannedBy'  in request.resource.data);
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['lastSeenAt', 'lastVersion', 'lastUserUid',
                                'platform', 'deviceLabel']);
      allow delete: if false;
    }
  }
}
