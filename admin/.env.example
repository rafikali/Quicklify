# Firebase Web SDK (client-safe — these are exposed to the browser).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK service-account JSON (server-only — DO NOT commit).
# Generate in Firebase Console → Project Settings → Service Accounts.
# Paste the entire single-line JSON; quotes escaped.
FIREBASE_SERVICE_ACCOUNT_JSON=
